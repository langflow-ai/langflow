# ─────────────────────────────────────────────────────────────────────────────
# Lothal production environment — template.
# Copy to the server as /opt/lothal/.env and fill every __CHANGE_ME__.
# The real .env is secret and must NEVER be committed (see deploy/.gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Postgres (containerized; internal to the compose network only) ──
POSTGRES_USER=lothal
POSTGRES_PASSWORD=__CHANGE_ME__
POSTGRES_DB=lothal

# ── Langflow / backend ──
# Note: LANGFLOW_DATABASE_URL is NOT set here. docker-compose.prod.yml derives it from the
# POSTGRES_* values above (single source of truth), so there's nothing to keep in sync.
LANGFLOW_CONFIG_DIR=/app/langflow
# ── Access control is ENFORCED in docker-compose.prod.yml, not here ──
# AUTO_LOGIN, ENABLE_SIGNUP, and NEW_USER_IS_ACTIVE are hardcoded to "false" in the
# compose file (invite-only: superuser provisions accounts via /admin, no self-signup).
# Setting them in this .env has NO effect — the compose literals win. To change the
# posture, edit docker-compose.prod.yml in a reviewed commit.
LANGFLOW_SUPERUSER=admin
LANGFLOW_SUPERUSER_PASSWORD=__CHANGE_ME__
# Persistent encryption key. Generate once with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
LANGFLOW_SECRET_KEY=__CHANGE_ME__

# ── Lothal LLM interface (Claude via Claude Code subscription) — Epic 0 onward ──
# The only implemented provider is "claude" (Claude Agent SDK). It authenticates
# with a Claude Code subscription's OAuth token — NOT a metered ANTHROPIC_API_KEY.
# Generate the token on a machine logged into Claude Code:
#     claude setup-token        # prints a long-lived CLAUDE_CODE_OAUTH_TOKEN
# (see scripts/claude_sdk_subscription.py). Without it every LLM endpoint 503s.
# WARNING: do NOT set ANTHROPIC_API_KEY — it overrides the subscription and bills
# per-token.
LOTHAL_LLM_PROVIDER=claude
# Optional model override (default: claude-opus-4-8). e.g. claude-haiku-4-5
LOTHAL_MODEL_NAME=
CLAUDE_CODE_OAUTH_TOKEN=__CHANGE_ME__

# ── Image refs ──
# The deploy workflow (C.3) overrides these with git-SHA-tagged images.
# The :latest defaults are fine for a manual `docker compose pull && up -d`.
BACKEND_IMAGE=ghcr.io/realbytecode/lothal-backend:latest
FRONTEND_IMAGE=ghcr.io/realbytecode/lothal-frontend:latest
