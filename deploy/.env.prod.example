# ─────────────────────────────────────────────────────────────────────────────
# Lothal production environment — template.
# Copy to the server as /opt/lothal/.env and fill every __CHANGE_ME__.
# The real .env is secret and must NEVER be committed (see deploy/.gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Postgres (containerized; internal to the compose network only) ──
POSTGRES_USER=lothal
POSTGRES_PASSWORD=__CHANGE_ME__
POSTGRES_DB=lothal

# ── Langflow / backend ──
# Note: LANGFLOW_DATABASE_URL is NOT set here. docker-compose.prod.yml derives it from the
# POSTGRES_* values above (single source of truth), so there's nothing to keep in sync.
LANGFLOW_CONFIG_DIR=/app/langflow
# ── Access control is ENFORCED in docker-compose.prod.yml, not here ──
# AUTO_LOGIN, ENABLE_SIGNUP, and NEW_USER_IS_ACTIVE are hardcoded to "false" in the
# compose file (invite-only: superuser provisions accounts via /admin, no self-signup).
# Setting them in this .env has NO effect — the compose literals win. To change the
# posture, edit docker-compose.prod.yml in a reviewed commit.
LANGFLOW_SUPERUSER=admin
LANGFLOW_SUPERUSER_PASSWORD=__CHANGE_ME__
# Persistent encryption key. Generate once with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
LANGFLOW_SECRET_KEY=__CHANGE_ME__

# ── Lothal LLM interface (Claude via Claude Code subscription) — Epic 0 onward ──
# The only implemented provider is "claude" (Claude Agent SDK). It authenticates
# with a Claude Code subscription's OAuth token — NOT a metered ANTHROPIC_API_KEY.
# Generate the token on a machine logged into Claude Code:
#     claude setup-token        # prints a long-lived CLAUDE_CODE_OAUTH_TOKEN
# (see scripts/claude_sdk_subscription.py). Without it every LLM endpoint 503s.
# WARNING: do NOT set ANTHROPIC_API_KEY — it overrides the subscription and bills
# per-token.
LOTHAL_LLM_PROVIDER=claude
# Optional model override (default: claude-opus-4-8). e.g. claude-haiku-4-5
LOTHAL_MODEL_NAME=
CLAUDE_CODE_OAUTH_TOKEN=__CHANGE_ME__

# ── Lothal LLM gateway (Open Design) — Epic U.3 ──
# A SEPARATE path from the chat provider above. Open Design's coding agent makes
# its own LLM calls; to keep them observable + centrally controlled we point OD's
# OpenAI-compatible `codex` agent at this gateway (backend route
# /api/v1/lothal/gateway/v1/chat/completions). It has TWO backends:
#
# (1) SUBSCRIPTION (default, no extra cost): with NOTHING set below, the gateway
#     runs OD's calls on CLAUDE_CODE_OAUTH_TOKEN above — it translates OpenAI ⇄
#     Anthropic and authenticates with the subscription (tools + streaming work).
#     Point codex's model at a Claude model id. This is the recommended setup.
#
# (2) METERED pass-through (optional override): set BOTH vars below to forward each
#     call VERBATIM to an OpenAI-compatible upstream on a metered key instead.
#     Takes precedence over the subscription when set. Examples:
#       OpenAI:    https://api.openai.com/v1     + an OpenAI key
#       Anthropic: https://api.anthropic.com/v1  + an ANTHROPIC key (serves Claude)
# LOTHAL_GATEWAY_UPSTREAM_BASE_URL=
# LOTHAL_GATEWAY_UPSTREAM_API_KEY=
#
# Inbound bearer the OD agent must present (sent as its OPENAI_API_KEY). Optional:
# unset = auth off, access rests on the private compose network (OD's own posture).
# Set it (openssl rand -hex 32) for defense-in-depth; it must match the value wired
# into OD's agentCliEnv.codex.OPENAI_API_KEY (see deploy/RUNBOOK.md, applied in U.4).
# LOTHAL_GATEWAY_TOKEN=

# ── Image refs ──
# The deploy workflow (C.3) overrides these with git-SHA-tagged images.
# The :latest defaults are fine for a manual `docker compose pull && up -d`.
BACKEND_IMAGE=ghcr.io/realbytecode/lothal-backend:latest
FRONTEND_IMAGE=ghcr.io/realbytecode/lothal-frontend:latest

# ── Open Design (OD) ──
# Published by the separate realbytecode/open-design repo's own workflow (Epic U.2)
# as ghcr.io/realbytecode/od (tagged per release; the image bakes in the Claude
# Code agent so OD has an available agent on boot). NOT built by the Lothal deploy.
# Pin a specific version/digest here and roll OD by editing this value +
# `docker compose -f docker-compose.prod.yml up -d open-design` — no Lothal code
# deploy needed. Prefer an immutable tag/digest over :latest in production.
OD_IMAGE=ghcr.io/realbytecode/od:0.11.2
# OD is internal-only and runs with API auth disabled by default (the compose sets
# OD_DISABLE_API_AUTH=1 unless overridden here), protected by the private compose
# network — no token needed. For defense-in-depth, set BOTH of the next two: a bearer
# token (the backend must then send it) AND flip the disable flag off, so the daemon
# actually enforces the token instead of running open.
# OD_API_TOKEN=          # generate with: openssl rand -hex 32
# OD_DISABLE_API_AUTH=0
# Optional container memory cap (default 384m).
# OD_MEM_LIMIT=384m
# OD origin-guard allow-list (Epic U.9). Required for the embed: OD rejects /api
# writes whose Host is a non-loopback DNS name unless the request Origin is listed.
# Must contain the backend's internal origin (so config writes succeed) AND the
# browser-facing OD origin (so the embedded web UI's /api calls pass). The compose
# default already includes the internal one; ADD your public OD origin here:
OD_ALLOWED_ORIGINS=http://open-design:7456,https://od.lothal.app

# ── Lothal PM service (the planning stage) ──
# Published by the separate realbytecode/lothal_project repo's own CI as
# ghcr.io/realbytecode/lothal (NOT the Lothal deploy workflow). The `pm` service is
# internal-only — the backend bridges to it server-side and re-exposes its routes as
# the canonical Lothal API. Roll it by editing PM_IMAGE then
# `docker compose -f docker-compose.prod.yml up -d pm`. Prefer an immutable tag.
PM_IMAGE=ghcr.io/realbytecode/lothal:latest
# Dedicated database on the shared `db` Postgres — NOT the langflow `lothal` DB.
# Create the role + database once (see deploy/RUNBOOK.md); the app builds its schema
# on first boot (LOTHAL_AUTO_CREATE=true). Set PM_AUTO_CREATE=false once it's stable.
PM_DB_NAME=lothal_pm
PM_DB_USER=lothal_pm
PM_DB_PASSWORD=__CHANGE_ME__
# Persistent JWT signing key for the PM service. Generate once:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
PM_SECRET_KEY=__CHANGE_ME__

# ── Prototype stage: backend → Open Design client (Epic UI U.4-U.7) ──
# The backend drives OD as a headless prototyping engine: it creates an OD
# project, starts a design run, reads artifacts back, and (on approve) copies
# them into its own store. All of the following are OPTIONAL with sane compose
# defaults; set them only to override.
#
# Where the backend reaches the OD daemon (defaults to the compose service name).
# LOTHAL_OD_BASE_URL=http://open-design:7456
# Bearer for OD's API. Only needed if you enabled OD_API_TOKEN + OD_DISABLE_API_AUTH=0
# above; the client falls back to OD_API_TOKEN automatically, so you rarely set this.
# LOTHAL_OD_API_TOKEN=
# The OD agent the backend drives — it's pointed at Lothal's gateway (U.3) and used
# for every run. MUST name an agent that is installed AND available in the OD image:
# check `GET <od>/api/agents` and use one with "available": true. The bare image's
# historical default `codex` is frequently NOT available; `claude` is. Blank = let
# OD pick its own default (skips the agent-config write). Compose default: claude.
# LOTHAL_OD_AGENT_ID=claude
# Optional OD skill id; blank = OD infers the prototype skill from the brief.
# LOTHAL_OD_SKILL_ID=
# Where OD reaches Lothal's LLM gateway (set into the codex agent's OPENAI_BASE_URL
# on generate). Defaults to the compose backend service.
# LOTHAL_GATEWAY_PUBLIC_URL=http://backend:7860/api/v1/lothal/gateway/v1
# Browser-facing OD base URL for embedding OD's web surface in the Workspace
# prototype pane (U.9), behind host nginx. UNSET = no iframe; the pane lists the
# produced artifacts instead. The internal LOTHAL_OD_BASE_URL is NOT browser-
# reachable, so this must be the public, nginx-fronted URL.
LOTHAL_OD_PUBLIC_BASE_URL=https://od.lothal.app

# ── Embedded OD auth gate (Epic U.9) ──
# The od.<domain> vhost (deploy/nginx/lothal.conf) gates the embed by the logged-in
# Lothal session via auth_request. For the session cookie to reach the subdomain
# (and ride into the iframe), scope it to the registrable domain — leading dot:
LANGFLOW_COOKIE_DOMAIN=.lothal.app

# ── OD's claude agent → Lothal gateway (Anthropic; Story U.3/U.9) — OPTIONAL ──
# OD's `claude` agent and its memory-llm read the LLM endpoint from the OD
# CONTAINER environment (process.env.ANTHROPIC_BASE_URL), not from OD's per-agent
# config — so the gateway is wired via container env vars passed through in
# docker-compose.prod.yml. Those already DEFAULT to the in-compose backend + an
# off-auth placeholder, so OD's claude works without setting anything here. claude
# appends `/v1/messages`, so the base omits `/v1` (the gateway also serves
# /v1/chat/completions for OpenAI-format agents). The token is only an inbound pass
# — the gateway injects the real subscription (CLAUDE_CODE_OAUTH_TOKEN) upstream.
# Override below ONLY for a different topology, or set the tokens to match a
# LOTHAL_GATEWAY_TOKEN if you turn the gateway's inbound auth on.
# ANTHROPIC_BASE_URL=http://backend:7860/api/v1/lothal/gateway
# ANTHROPIC_AUTH_TOKEN=lothal
# ANTHROPIC_API_KEY=lothal
# CLAUDE_CONFIG_DIR=/app/.od/.claude
