# syntax=docker/dockerfile:1
# Single-Dockerfile cold-start benchmark image for lfx.
#
# Structurally mirrors src/lfx/docker/Dockerfile (builder -> runtime) and
# adds a `bench` stage that layers the flow's pinned deps + flow JSON + the
# concurrent-fire helper.
#
# Why Debian instead of Alpine (the production image base): some transitive
# lfx deps (onnxruntime etc.) ship manylinux-only wheels and fail to install
# on musl/linux_aarch64. Debian slim resolves cleanly on Apple Silicon.
#
# Why one Dockerfile instead of two: buildx's docker-container driver (used
# by Podman-over-the-docker-socket) can't see images in the local engine's
# store, so a two-image setup with `FROM lfx:bench-base` fails. Merging
# sidesteps that without sacrificing layer caching.
#
# Build context must contain:
#   - flow.json                (in the repo root or wherever the harness puts it)
#   - flow_requirements.txt    (pinned; from `lfx requirements`)
#   - fire_concurrent.py       (host-to-pod concurrent launcher)

################################
# BUILDER
################################
FROM ghcr.io/astral-sh/uv:python3.12-bookworm-slim AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        libaio-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

ENV UV_COMPILE_BYTECODE=1
ENV UV_LINK_MODE=copy

COPY pyproject.toml uv.lock ./
COPY src/lfx/pyproject.toml /app/src/lfx/pyproject.toml
COPY src/lfx/README.md /app/src/lfx/README.md
COPY src/sdk/pyproject.toml /app/src/sdk/pyproject.toml
COPY src/sdk/README.md /app/src/sdk/README.md

RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-dev --package lfx

COPY src/lfx/src /app/src/lfx/src
COPY src/sdk/src /app/src/sdk/src

RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-dev --no-editable --package lfx

################################
# RUNTIME (base lfx install -- mirrors the production Alpine Dockerfile)
################################
FROM python:3.12-slim-bookworm AS runtime

RUN groupadd -g 1000 lfx \
    && useradd -m -u 1000 -g lfx -d /app/data -s /usr/sbin/nologin lfx

COPY --from=builder --chown=1000:1000 /app/.venv /app/.venv

ENV PATH="/app/.venv/bin:$PATH"

USER lfx
WORKDIR /app/data

CMD ["lfx", "--help"]

################################
# BENCH (flow-specific deps + flow + helper, long-lived pod)
################################
FROM runtime AS bench

USER root

# uv binary for installing flow deps into the existing venv.
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /usr/local/bin/

# Scratch dir for the reqs file.
COPY scripts/bench/flow_requirements.txt /tmp/flow_requirements.txt

ENV UV_COMPILE_BYTECODE=1

# Install flow deps. Build toolchain stays in the image -- stripping it on
# Debian is tedious and image size isn't critical for a local benchmark.
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        libxml2-dev \
        libxslt1-dev \
        libffi-dev \
        libssl-dev \
    && uv pip install --python /app/.venv/bin/python --no-cache -r /tmp/flow_requirements.txt \
    && rm -rf /var/lib/apt/lists/*

COPY --chown=1000:1000 scripts/bench/flow.json /app/data/flow.json
COPY --chown=1000:1000 scripts/bench/inputoutput.json /app/data/inputoutput.json
COPY --chown=1000:1000 scripts/bench/agentcpuflow.json /app/data/agentcpuflow.json
COPY --chown=1000:1000 scripts/bench/agentcpuflowmore.json /app/data/agentcpuflowmore.json
COPY --chown=1000:1000 scripts/bench/fire_concurrent.py /app/data/fire_concurrent.py

# Forkserver + prewarm harness (models the PLANNED TRM fork-from-warm path).
# Run INSIDE the container (forkserver/CoW are Linux-only):
#   C=$(podman run -d --rm -e OPENAI_API_KEY lfx-coldstart:bench)
#   podman exec -w /app/data $C python forkserver_bench.py cold inputoutput.json "hi" 10
#   podman exec -w /app/data $C python forkserver_bench.py warm inputoutput.json "hi" 10
#   podman exec -w /app/data $C python forkserver_bench.py warm flow.json "say a random number" 10
# The no-LLM (inputoutput.json) warm run is the unambiguous "CoW working" signal.
COPY --chown=1000:1000 scripts/bench/forkserver_bench.py /app/data/forkserver_bench.py
COPY --chown=1000:1000 scripts/bench/_lfx_prewarm_shim.py /app/data/_lfx_prewarm_shim.py

USER lfx
WORKDIR /app/data

# Long-lived pod. Two ways to drive it:
#   * baseline + intermediate: `lfx run` per call via `podman exec` (nested subprocess)
#   * end-state fix: forkserver_bench.py warm/cold (fork-from-warm, in-process)
CMD ["sleep", "infinity"]
