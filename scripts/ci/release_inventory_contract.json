          "lfx_ollama/components/ollama/ollama_embeddings.py"
        ],
        "lfx-bundles": [
          "lfx_bundles/mongodb/mongodb_atlas.py",
          "lfx_bundles/codeagents/starter_projects/Structured Data Analysis Agent.json",
          "lfx_bundles/youtube/starter_projects/Youtube Analysis.json"
        ]
      },
      "module_checks": [
        {
          "module": "lfx.components.google",
          "attribute": "GoogleGenerativeAIComponent",
          "expect": "success"
        },
        {
          "module": "lfx.components.azure",
          "attribute": "AzureChatOpenAIComponent",
          "expect": "success"
        },
        {
          "module": "lfx.components.ollama",
          "attribute": "ChatOllamaComponent",
          "expect": "success"
        },
        {
          "module": "langchain_azure_ai.chat_models",
          "attribute": "AzureAIOpenAIApiChatModel",
          "expect": "success"
        },
        {
          "module": "langchain_ollama",
          "attribute": "ChatOllama",
          "expect": "success"
        },
        {
          "module": "lfx.components.youtube",
          "attribute": "YouTubeTranscriptsComponent",
          "expect": "success"
        }
      ]
    },
    "image-core": {
      "extends": "python-core"
    },
    "image-default": {
      "extends": "python-default"
    },
    "image-full": {
      "extends": "python-full"
    }
  }
}
