# Copy to .env and fill in. Do not commit .env.

LANGFLOW_BASE_URL=http://localhost:7860
LANGFLOW_API_KEY=
FLOW_ID=

# --- Postgres (proxy + ingest) ---
# DigitalOcean: use connection string from dashboard. Add ?sslmode=require if not present.
DATABASE_URL=postgresql://user:pass@host:25060/defaultdb?sslmode=require

# --- Ingest script (ingest_docs.py) only ---
OPENAI_API_KEY=

# Optional for ingest_docs.py:
# DOCS_PATH=          # default: docs/docs (repo docs content)
# COLLECTION_NAME=    # default: langflow_docs (table name; set same in Langflow PGVector)
# PRE_DELETE_COLLECTION=1   # set to 1 to replace table on re-run